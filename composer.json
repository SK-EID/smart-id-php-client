{
  "name": "sk-id-solutions/smart-id-php-client",
  "type": "library",
  "description": "Smart-ID PHP client",
  "homepage": "https://github.com/SK-EID/smart-id-php-client",
  "keywords": [
    "smart-id",
    "relying",
    "party",
    "api"
  ],
  "license": "MIT",
  "authors": [],
  "require": {
    "php": ">=8.4",
    "ext-json": "*",
    "ext-curl": "*",
    "ext-openssl": "*",
    "phpseclib/phpseclib": "~3.0",
    "guzzlehttp/guzzle": "^7.0",
    "guzzlehttp/psr7": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5",
    "friendsofphp/php-cs-fixer": "^3.65",
    "phpstan/phpstan": "^2.1"
  },
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "Sk\\SmartId\\": "src/Sk/SmartId/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sk\\SmartId\\Tests\\": "tests/Sk/SmartId/Tests/"
    }
  },
    "scripts": {
    "test": "phpunit",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "phpstan": "phpstan analyse"
  }
}
