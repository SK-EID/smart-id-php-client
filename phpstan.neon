parameters:
    level: 6
    paths:
        - src
    excludePaths:
        - vendor
        - examples
    reportUnmatchedIgnoredErrors: false
    ignoreErrors:
        # Array type specifications - PHPStan level 6 requires verbose generics
        - identifier: missingType.iterableValue
        # isset() on array keys from external data (API responses)
        - identifier: isset.property
